# Copy to .env or .env.local (Vite loads both). Restart dev server after changes.
# Only variables prefixed with VITE_ are exposed to the browser.

# Option A — browser calls backend directly (CORS must allow this origin on the API):
# VITE_API_URL=http://localhost:8000/api

# Option B — same-origin /api in dev (vite.config.ts proxies /api -> http://localhost:8000):
VITE_API_URL=/api

VITE_SOCKET_URL=http://localhost:8000
